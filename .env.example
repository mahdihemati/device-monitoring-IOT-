APP_NAME="Blood Refrigerator Monitor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=device_monitoring
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

INGESTION_SECRET=change-this-local-secret
LOGIN_RATE_LIMIT_PER_MINUTE=5
INGESTION_RATE_LIMIT_PER_MINUTE=120

TEMP_MIN_CELSIUS=2
TEMP_MAX_CELSIUS=6
DOOR_OPEN_IS_ALARM=true
DOOR_TRUE_MEANS_OPEN=true
PF_TRUE_MEANS_FAULT=true
OFFLINE_AFTER_SECONDS=30
OFFLINE_AFTER_MINUTES=1

MQTT_HOST=185.105.239.74
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_AUTH_TOKEN=wwqe22yoqx2t6lcs6kv2
MQTT_CLIENT_ID=blood-refrigerator-monitor
MQTT_TOPIC=v1/devices/me/telemetry
MQTT_QOS=0
MQTT_KEEP_ALIVE=60
MQTT_USE_TLS=false
MQTT_DEVICE_CODE_TOPIC_REGEX=
